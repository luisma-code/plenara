{
  "skillId": "recall-mood",
  "displayName": "Show your recent moods",
  "reads": [
    "mood"
  ],
  "writes": [],
  "inputs": [],
  "steps": {
    "main": [
      { "op": "read_many", "typeId": "mood", "orderBy": "loggedAt", "orderDir": "asc", "into": "moods" },
      { "op": "set", "var": "lines", "value": "" },
      { "op": "set", "var": "k", "value": 0 },
      {
        "op": "foreach",
        "list": { "var": "moods" },
        "as": "m",
        "body": [
          { "op": "compute", "fn": "add", "args": [ { "var": "k" }, 1 ], "into": "k" },
          {
            "op": "compute",
            "fn": "concat",
            "args": [
              { "var": "lines" },
              "\n  ",
              { "var": "k" },
              ". ",
              { "field": [ "m", "loggedAt" ] },
              ": ",
              { "field": [ "m", "rating" ] }
            ],
            "into": "lines"
          },
          { "op": "ref_mark", "typeId": "mood", "id": { "field": [ "m", "id" ] }, "field": "rating" }
        ]
      },
      { "op": "compute", "fn": "count", "args": [ { "var": "moods" } ], "into": "n" },
      {
        "op": "branch",
        "cond": { "gte": [ { "var": "n" }, 1 ] },
        "then": [
          { "op": "format", "template": "You've logged {n} mood(s):{lines}", "into": "confirmationText" }
        ],
        "else": [
          { "op": "format", "template": "You haven't logged any moods yet.", "into": "confirmationText" }
        ]
      }
    ]
  }
}
