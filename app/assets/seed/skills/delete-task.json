{
  "skillId": "delete-task",
  "displayName": "Delete a task",
  "reads": [
    "task"
  ],
  "writes": [
    "task"
  ],
  "inputs": [
    {
      "name": "description",
      "required": true
    }
  ],
  "steps": {
    "main": [
      {
        "op": "read_one",
        "typeId": "task",
        "match": {
          "description": {
            "var": "description"
          }
        },
        "into": "t",
        "partial": true
      },
      {
        "op": "branch",
        "cond": {
          "isNull": "t"
        },
        "then": [
          {
            "op": "format",
            "template": "I couldn't find a task \"{description}\".",
            "into": "confirmationText"
          }
        ],
        "else": [
          {
            "op": "delete_record",
            "id": {
              "ref": "t"
            }
          },
          {
            "op": "format",
            "template": "Deleted \"{description}\".",
            "into": "confirmationText"
          }
        ]
      }
    ]
  }
}
