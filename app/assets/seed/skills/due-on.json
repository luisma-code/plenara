{
  "skillId": "due-on",
  "displayName": "Show tasks due on a day",
  "reads": [
    "task"
  ],
  "writes": [],
  "inputs": [
    { "name": "day", "required": true, "type": "date" }
  ],
  "steps": {
    "main": [
      {
        "op": "read_many",
        "typeId": "task",
        "filter": [
          { "field": "completed", "op": "neq", "value": true },
          { "field": "dueAt", "op": "eq", "value": { "var": "day" } }
        ],
        "orderBy": "dueAt",
        "orderDir": "asc",
        "into": "tasks"
      },
      { "op": "set", "var": "lines", "value": "" },
      { "op": "set", "var": "k", "value": 0 },
      {
        "op": "foreach",
        "list": { "var": "tasks" },
        "as": "t",
        "body": [
          { "op": "compute", "fn": "add", "args": [ { "var": "k" }, 1 ], "into": "k" },
          {
            "op": "compute",
            "fn": "concat",
            "args": [ { "var": "lines" }, "\n  ", { "var": "k" }, ". ", { "field": [ "t", "description" ] } ],
            "into": "lines"
          },
          { "op": "ref_mark", "typeId": "task", "id": { "field": [ "t", "id" ] }, "field": "description" }
        ]
      },
      { "op": "compute", "fn": "count", "args": [ { "var": "tasks" } ], "into": "n" },
      { "op": "compute", "fn": "format_date", "args": [ { "var": "day" }, "EEEE" ], "into": "dayLabel" },
      {
        "op": "branch",
        "cond": { "gte": [ { "var": "n" }, 1 ] },
        "then": [
          { "op": "format", "template": "{n} task(s) due {dayLabel}:{lines}", "into": "confirmationText" }
        ],
        "else": [
          { "op": "format", "template": "Nothing due {dayLabel}.", "into": "confirmationText" }
        ]
      }
    ]
  }
}
