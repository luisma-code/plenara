{
  "skillId": "list-interactions",
  "displayName": "List your logged interactions with a person",
  "reads": [
    "contact",
    "interaction"
  ],
  "writes": [],
  "inputs": [
    { "name": "personName", "required": true }
  ],
  "steps": {
    "main": [
      {
        "op": "read_one",
        "typeId": "contact",
        "match": { "displayName": { "var": "personName" } },
        "partial": true,
        "into": "person"
      },
      {
        "op": "branch",
        "cond": { "isNull": "person" },
        "then": [
          {
            "op": "format",
            "template": "I don't have {personName} as a contact yet.",
            "into": "confirmationText"
          }
        ],
        "else": [
          {
            "op": "read_related",
            "typeId": "interaction",
            "via": "subject",
            "from": { "ref": "person" },
            "into": "ints"
          },
          { "op": "set", "var": "lines", "value": "" },
          { "op": "set", "var": "k", "value": 0 },
          {
            "op": "foreach",
            "list": { "var": "ints" },
            "as": "i",
            "body": [
              { "op": "compute", "fn": "add", "args": [ { "var": "k" }, 1 ], "into": "k" },
              {
                "op": "compute",
                "fn": "format_date",
                "args": [ { "field": [ "i", "at" ] }, "EEEE" ],
                "into": "d"
              },
              {
                "_comment": "Build the line incrementally: number, date, then the kind (dinner/coffee/call…) if the interaction has one, then the note if present (reviewer b #8).",
                "op": "compute",
                "fn": "concat",
                "args": [ { "var": "lines" }, "\n  ", { "var": "k" }, ". ", { "field": [ "i", "at" ] }, " (", { "var": "d" }, ")" ],
                "into": "lines"
              },
              { "op": "ref_mark", "typeId": "interaction", "id": { "field": [ "i", "id" ] }, "field": "note", "label": { "field": [ "i", "at" ] } },
              {
                "op": "set",
                "var": "kindText",
                "value": { "field": [ "i", "kind" ] }
              },
              {
                "op": "branch",
                "cond": { "notNull": "kindText" },
                "then": [
                  {
                    "op": "compute",
                    "fn": "concat",
                    "args": [ { "var": "lines" }, " — ", { "var": "kindText" } ],
                    "into": "lines"
                  }
                ]
              },
              {
                "op": "set",
                "var": "noteText",
                "value": { "field": [ "i", "note" ] }
              },
              {
                "op": "branch",
                "cond": { "notNull": "noteText" },
                "then": [
                  {
                    "op": "compute",
                    "fn": "concat",
                    "args": [ { "var": "lines" }, " — ", { "var": "noteText" } ],
                    "into": "lines"
                  }
                ]
              }
            ]
          },
          {
            "op": "compute",
            "fn": "count",
            "args": [ { "var": "ints" } ],
            "into": "n"
          },
          {
            "op": "branch",
            "cond": { "gte": [ { "var": "n" }, 1 ] },
            "then": [
              {
                "op": "format",
                "template": "You've logged {n} interaction(s) with {personName}:{lines}",
                "into": "confirmationText"
              }
            ],
            "else": [
              {
                "op": "format",
                "template": "You haven't logged any interactions with {personName} yet.",
                "into": "confirmationText"
              }
            ]
          }
        ]
      }
    ]
  }
}
