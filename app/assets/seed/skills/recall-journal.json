{
  "skillId": "recall-journal",
  "displayName": "Read your journal",
  "reads": [
    "journal_entry"
  ],
  "writes": [],
  "inputs": [],
  "steps": {
    "main": [
      { "op": "read_many", "typeId": "journal_entry", "orderBy": "loggedAt", "orderDir": "asc", "into": "entries" },
      { "op": "set", "var": "lines", "value": "" },
      { "op": "set", "var": "k", "value": 0 },
      {
        "op": "foreach",
        "list": { "var": "entries" },
        "as": "e",
        "body": [
          { "op": "compute", "fn": "add", "args": [ { "var": "k" }, 1 ], "into": "k" },
          {
            "op": "compute",
            "fn": "concat",
            "args": [
              { "var": "lines" },
              "\n  ",
              { "var": "k" },
              ". ",
              { "field": [ "e", "loggedAt" ] },
              ": ",
              { "field": [ "e", "entry" ] }
            ],
            "into": "lines"
          },
          { "op": "ref_mark", "typeId": "journal_entry", "id": { "field": [ "e", "id" ] }, "field": "entry" }
        ]
      },
      { "op": "compute", "fn": "count", "args": [ { "var": "entries" } ], "into": "n" },
      {
        "op": "branch",
        "cond": { "gte": [ { "var": "n" }, 1 ] },
        "then": [
          { "op": "format", "template": "Your journal — {n} entries:{lines}", "into": "confirmationText" }
        ],
        "else": [
          { "op": "format", "template": "Your journal is empty.", "into": "confirmationText" }
        ]
      }
    ]
  }
}
