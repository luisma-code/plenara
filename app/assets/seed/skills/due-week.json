{
  "skillId": "due-week",
  "displayName": "Show tasks due this week",
  "reads": [
    "task"
  ],
  "writes": [],
  "inputs": [],
  "steps": {
    "main": [
      { "op": "compute", "fn": "today", "into": "today" },
      { "op": "compute", "fn": "start_of_week", "args": [ { "var": "today" } ], "into": "sow" },
      { "op": "compute", "fn": "add_days", "args": [ { "var": "sow" }, 7 ], "into": "eow" },
      {
        "op": "read_many",
        "typeId": "task",
        "filter": [
          { "field": "completed", "op": "neq", "value": true },
          { "field": "dueAt", "op": "gte", "value": { "var": "sow" } },
          { "field": "dueAt", "op": "lt", "value": { "var": "eow" } }
        ],
        "orderBy": "dueAt",
        "orderDir": "asc",
        "into": "tasks"
      },
      { "op": "set", "var": "lines", "value": "" },
      {
        "op": "foreach",
        "list": { "var": "tasks" },
        "as": "t",
        "body": [
          { "op": "compute", "fn": "format_date", "args": [ { "field": [ "t", "dueAt" ] }, "EEEE" ], "into": "d" },
          {
            "op": "compute",
            "fn": "concat",
            "args": [ { "var": "lines" }, "\n  • ", { "field": [ "t", "description" ] }, " — ", { "var": "d" } ],
            "into": "lines"
          }
        ]
      },
      { "op": "compute", "fn": "count", "args": [ { "var": "tasks" } ], "into": "n" },
      {
        "op": "branch",
        "cond": { "gte": [ { "var": "n" }, 1 ] },
        "then": [
          { "op": "format", "template": "{n} task(s) due this week:{lines}", "into": "confirmationText" }
        ],
        "else": [
          { "op": "format", "template": "Nothing due this week.", "into": "confirmationText" }
        ]
      }
    ]
  }
}
