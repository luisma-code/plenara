{
  "skillId": "list-tasks",
  "displayName": "List your tasks",
  "reads": [
    "task"
  ],
  "writes": [],
  "inputs": [],
  "steps": {
    "main": [
      {
        "op": "read_many",
        "typeId": "task",
        "filter": { "field": "completed", "op": "neq", "value": true },
        "orderBy": "createdAt",
        "orderDir": "asc",
        "into": "tasks"
      },
      {
        "op": "enumerate",
        "list": { "var": "tasks" },
        "label": "description",
        "into": "lines"
      },
      {
        "op": "compute",
        "fn": "count",
        "args": [
          {
            "var": "tasks"
          }
        ],
        "into": "n"
      },
      {
        "op": "format",
        "template": "You have {n} task(s):{lines}",
        "into": "confirmationText"
      }
    ]
  }
}
