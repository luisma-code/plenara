{
  "skillId": "list-completed-tasks",
  "displayName": "Completed tasks",
  "reads": [
    "task"
  ],
  "writes": [],
  "inputs": [],
  "steps": {
    "main": [
      {
        "op": "read_many",
        "typeId": "task",
        "filter": {
          "field": "completed",
          "op": "eq",
          "value": true
        },
        "into": "done"
      },
      {
        "op": "enumerate",
        "list": { "var": "done" },
        "label": "description",
        "into": "out"
      },
      {
        "op": "compute",
        "fn": "count",
        "args": [ { "var": "done" } ],
        "into": "n"
      },
      {
        "op": "branch",
        "cond": {
          "eq": [
            {
              "var": "n"
            },
            0
          ]
        },
        "then": [
          {
            "op": "format",
            "template": "You haven't completed any tasks yet.",
            "into": "confirmationText"
          }
        ],
        "else": [
          {
            "op": "format",
            "template": "Completed:{out}",
            "into": "confirmationText"
          }
        ]
      }
    ]
  }
}
