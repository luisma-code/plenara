{
  "templateId": "medication",
  "displayName": "medication tracking",
  "keywords": [
    "medication",
    "meds",
    "medicine",
    "my pills",
    "my medication"
  ],
  "example": "log that I took my meds",
  "types": [
    {
      "typeId": "medication_log",
      "displayName": "Medication",
      "attributes": [
        {
          "name": "note",
          "valueType": "text",
          "required": false
        },
        {
          "name": "loggedAt",
          "valueType": "date",
          "required": true
        }
      ]
    }
  ],
  "skills": [
    {
      "skillId": "log-medication",
      "displayName": "Log medication",
      "reads": [],
      "writes": [
        "medication_log"
      ],
      "inputs": [
        {
          "name": "note",
          "required": false
        }
      ],
      "steps": {
        "main": [
          {
            "op": "compute",
            "fn": "today",
            "into": "today"
          },
          {
            "op": "write_record",
            "typeId": "medication_log",
            "fields": {
              "note": {
                "var": "note"
              },
              "loggedAt": {
                "var": "today"
              }
            },
            "into": "m"
          },
          {
            "op": "format",
            "template": "Logged — you took your medication today.",
            "into": "confirmationText"
          }
        ]
      }
    },
    {
      "skillId": "meds-today",
      "displayName": "Medication taken today (adherence check)",
      "reads": [
        "medication_log"
      ],
      "writes": [],
      "inputs": [],
      "steps": {
        "main": [
          {
            "op": "compute",
            "fn": "today",
            "into": "today"
          },
          {
            "op": "read_many",
            "typeId": "medication_log",
            "into": "logs"
          },
          {
            "op": "set",
            "var": "count",
            "value": 0
          },
          {
            "op": "foreach",
            "list": {
              "var": "logs"
            },
            "as": "e",
            "body": [
              {
                "op": "branch",
                "cond": {
                  "gte": [
                    {
                      "field": [
                        "e",
                        "loggedAt"
                      ]
                    },
                    {
                      "var": "today"
                    }
                  ]
                },
                "then": [
                  {
                    "op": "compute",
                    "fn": "add",
                    "args": [
                      {
                        "var": "count"
                      },
                      1
                    ],
                    "into": "count"
                  }
                ]
              }
            ]
          },
          {
            "op": "branch",
            "cond": {
              "gte": [
                {
                  "var": "count"
                },
                1
              ]
            },
            "then": [
              {
                "op": "format",
                "template": "Yes — you've logged your medication {count} time(s) today.",
                "into": "confirmationText"
              }
            ],
            "else": [
              {
                "op": "format",
                "template": "Not yet today — you haven't logged your medication.",
                "into": "confirmationText"
              }
            ]
          }
        ]
      }
    }
  ],
