{
  "templateId": "steps",
  "displayName": "step tracking",
  "keywords": ["steps", "my steps", "step count", "daily steps", "walking steps"],
  "example": "log 8000 steps",
  "types": [
    {
      "typeId": "step_log",
      "displayName": "Steps",
      "attributes": [
        { "name": "count", "valueType": "number", "required": false },
        { "name": "loggedAt", "valueType": "date", "required": true }
      ]
    }
  ],
  "skills": [
    {
      "skillId": "log-steps",
      "displayName": "Log steps",
      "reads": [],
      "writes": [ "step_log" ],
      "inputs": [ { "name": "count", "required": false } ],
      "steps": {
        "main": [
          { "op": "compute", "fn": "today", "into": "today" },
          {
            "op": "write_record",
            "typeId": "step_log",
            "fields": { "count": { "var": "count" }, "loggedAt": { "var": "today" } },
            "into": "s"
          },
          {
            "op": "branch",
            "cond": { "notNull": "count" },
            "then": [ { "op": "format", "template": "Logged {count} steps today.", "into": "confirmationText" } ],
            "else": [ { "op": "format", "template": "Logged your steps today.", "into": "confirmationText" } ]
          }
        ]
      }
    },
    {
      "skillId": "steps-this-week",
      "displayName": "Total steps this week",
      "reads": [ "step_log" ],
      "writes": [],
      "inputs": [],
      "steps": {
        "main": [
          { "op": "compute", "fn": "start_of_week", "args": [ { "fn": "today" } ], "into": "weekStart" },
          { "op": "read_many", "typeId": "step_log", "into": "logs" },
          { "op": "set", "var": "total", "value": 0 },
          {
            "op": "foreach",
            "list": { "var": "logs" },
            "as": "e",
            "body": [
              {
                "op": "branch",
                "cond": { "gte": [ { "field": [ "e", "loggedAt" ] }, { "var": "weekStart" } ] },
                "then": [
                  { "op": "compute", "fn": "add", "args": [ { "var": "total" }, { "field": [ "e", "count" ] } ], "into": "total" }
                ]
              }
            ]
          },
          { "op": "format", "template": "You've logged {total} steps so far this week.", "into": "confirmationText" }
        ]
      }
    }
  ],
  "corpus": [
    { "skillId": "log-steps", "template": "log {count:quantity} steps" },
    { "skillId": "log-steps", "template": "i walked {count:quantity} steps" },
    { "skillId": "log-steps", "template": "i did {count:quantity} steps today" },
    { "skillId": "steps-this-week", "template": "how many steps this week" },
    { "skillId": "steps-this-week", "template": "how many steps have i done this week" },
    { "skillId": "steps-this-week", "template": "how many steps did i do this week" },
    { "skillId": "steps-this-week", "template": "what's my step count this week" },
    { "skillId": "steps-this-week", "template": "steps this week" }
  ]
}
