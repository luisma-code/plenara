{
  "templateId": "steps",
  "displayName": "step tracking",
  "keywords": [
    "steps",
    "my steps",
    "step count",
    "daily steps",
    "walking steps"
  ],
  "example": "log 8000 steps",
  "types": [
    {
      "typeId": "step_log",
      "displayName": "Steps",
      "attributes": [
        {
          "name": "count",
          "valueType": "number",
          "required": false
        },
        {
          "name": "loggedAt",
          "valueType": "date",
          "required": true
        }
      ]
    }
  ],
  "skills": [
    {
      "skillId": "log-steps",
      "displayName": "Log steps",
      "reads": [],
      "writes": [
        "step_log"
      ],
      "inputs": [
        {
          "name": "count",
          "required": false
        }
      ],
      "steps": {
        "main": [
          {
            "op": "compute",
            "fn": "today",
            "into": "today"
          },
          {
            "op": "write_record",
            "typeId": "step_log",
            "fields": {
              "count": {
                "var": "count"
              },
              "loggedAt": {
                "var": "today"
              }
            },
            "into": "s"
          },
          {
            "op": "branch",
            "cond": {
              "notNull": "count"
            },
            "then": [
              {
                "op": "format",
                "template": "Logged {count} steps today.",
                "into": "confirmationText"
              }
            ],
            "else": [
              {
                "op": "format",
                "template": "Logged your steps today.",
                "into": "confirmationText"
              }
            ]
          }
        ]
      }
    },
    {
      "skillId": "steps-this-week",
      "displayName": "Total steps this week",
      "reads": [
        "step_log"
      ],
      "writes": [],
      "inputs": [],
      "steps": {
        "main": [
          {
            "op": "compute",
            "fn": "start_of_week",
            "args": [
              {
                "fn": "today"
              }
            ],
            "into": "weekStart"
          },
          {
            "op": "read_many",
            "typeId": "step_log",
            "into": "logs"
          },
          {
            "op": "set",
            "var": "total",
            "value": 0
          },
          {
            "op": "foreach",
            "list": {
              "var": "logs"
            },
            "as": "e",
            "body": [
              {
                "op": "branch",
                "cond": {
                  "gte": [
                    {
                      "field": [
                        "e",
                        "loggedAt"
                      ]
                    },
                    {
                      "var": "weekStart"
                    }
                  ]
                },
                "then": [
                  {
                    "op": "compute",
                    "fn": "add",
                    "args": [
                      {
                        "var": "total"
                      },
                      {
                        "field": [
                          "e",
                          "count"
                        ]
                      }
                    ],
                    "into": "total"
                  }
                ]
              }
            ]
          },
          {
            "op": "format",
            "template": "You've logged {total} steps so far this week.",
            "into": "confirmationText"
          }
        ]
      }
    },
    {
      "skillId": "steps-today",
      "displayName": "Steps today",
      "reads": [
        "step_log"
      ],
      "writes": [],
      "inputs": [],
      "steps": {
        "main": [
          {
            "op": "compute",
            "fn": "today",
            "into": "today"
          },
          {
            "op": "read_many",
            "typeId": "step_log",
            "into": "logs"
          },
          {
            "op": "set",
            "var": "total",
            "value": 0
          },
          {
            "op": "foreach",
            "list": {
              "var": "logs"
            },
            "as": "e",
            "body": [
              {
                "op": "branch",
                "cond": {
                  "gte": [
                    {
                      "field": [
                        "e",
                        "loggedAt"
                      ]
                    },
                    {
                      "var": "today"
                    }
                  ]
                },
                "then": [
                  {
                    "op": "compute",
                    "fn": "add",
                    "args": [
                      {
                        "var": "total"
                      },
                      {
                        "field": [
                          "e",
                          "count"
                        ]
                      }
                    ],
                    "into": "total"
                  }
                ]
              }
            ]
          },
          {
            "op": "format",
            "template": "You've logged {total} steps today.",
            "into": "confirmationText"
          }
        ]
      }
    }
  ],
