{
  "templateId": "water",
  "displayName": "water tracking",
  "keywords": [
    "water",
    "hydration",
    "water intake",
    "drinking water",
    "my water"
  ],
  "example": "log 500ml of water",
  "types": [
    {
      "typeId": "hydration",
      "displayName": "Water",
      "attributes": [
        {
          "name": "amount",
          "valueType": "decimal",
          "required": false
        },
        {
          "name": "loggedAt",
          "valueType": "date",
          "required": true
        }
      ]
    }
  ],
  "skills": [
    {
      "skillId": "log-water",
      "displayName": "Log water",
      "reads": [],
      "writes": [
        "hydration"
      ],
      "inputs": [
        {
          "name": "amount",
          "required": false
        }
      ],
      "steps": {
        "main": [
          {
            "op": "compute",
            "fn": "today",
            "into": "today"
          },
          {
            "op": "write_record",
            "typeId": "hydration",
            "fields": {
              "amount": {
                "var": "amount"
              },
              "loggedAt": {
                "var": "today"
              }
            },
            "into": "w"
          },
          {
            "op": "branch",
            "cond": {
              "notNull": "amount"
            },
            "then": [
              {
                "op": "format",
                "template": "Logged {amount} ml of water.",
                "into": "confirmationText"
              }
            ],
            "else": [
              {
                "op": "format",
                "template": "Logged a glass of water.",
                "into": "confirmationText"
              }
            ]
          }
        ]
      }
    },
    {
      "skillId": "water-today",
      "displayName": "Water logged today",
      "reads": [
        "hydration"
      ],
      "writes": [],
      "inputs": [],
      "steps": {
        "main": [
          {
            "op": "compute",
            "fn": "today",
            "into": "today"
          },
          {
            "op": "read_many",
            "typeId": "hydration",
            "into": "logs"
          },
          {
            "op": "set",
            "var": "total",
            "value": 0
          },
          {
            "op": "foreach",
            "list": {
              "var": "logs"
            },
            "as": "e",
            "body": [
              {
                "op": "branch",
                "cond": {
                  "gte": [
                    {
                      "field": [
                        "e",
                        "loggedAt"
                      ]
                    },
                    {
                      "var": "today"
                    }
                  ]
                },
                "then": [
                  {
                    "op": "compute",
                    "fn": "add",
                    "args": [
                      {
                        "var": "total"
                      },
                      {
                        "field": [
                          "e",
                          "amount"
                        ]
                      }
                    ],
                    "into": "total"
                  }
                ]
              }
            ]
          },
          {
            "op": "format",
            "template": "You've logged {total} ml of water today.",
            "into": "confirmationText"
          }
        ]
      }
    }
  ],
