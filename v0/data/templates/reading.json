{
  "templateId": "reading",
  "displayName": "reading tracking",
  "keywords": [
    "reading",
    "books i read",
    "reading habit",
    "pages i read",
    "my reading"
  ],
  "example": "log 30 pages of reading",
  "types": [
    {
      "typeId": "reading_log",
      "displayName": "Reading",
      "attributes": [
        {
          "name": "pages",
          "valueType": "decimal",
          "required": false
        },
        {
          "name": "loggedAt",
          "valueType": "date",
          "required": true
        }
      ]
    }
  ],
  "skills": [
    {
      "skillId": "log-reading",
      "displayName": "Log reading",
      "reads": [],
      "writes": [
        "reading_log"
      ],
      "inputs": [
        {
          "name": "pages",
          "required": false
        }
      ],
      "steps": {
        "main": [
          {
            "op": "compute",
            "fn": "today",
            "into": "today"
          },
          {
            "op": "write_record",
            "typeId": "reading_log",
            "fields": {
              "pages": {
                "var": "pages"
              },
              "loggedAt": {
                "var": "today"
              }
            },
            "into": "r"
          },
          {
            "op": "branch",
            "cond": {
              "notNull": "pages"
            },
            "then": [
              {
                "op": "format",
                "template": "Logged {pages} pages of reading today.",
                "into": "confirmationText"
              }
            ],
            "else": [
              {
                "op": "format",
                "template": "Logged a reading session today.",
                "into": "confirmationText"
              }
            ]
          }
        ]
      }
    },
    {
      "skillId": "reading-streak",
      "displayName": "Your reading streak",
      "reads": [
        "reading_log"
      ],
      "writes": [],
      "inputs": [],
      "steps": {
        "main": [
          {
            "op": "read_many",
            "typeId": "reading_log",
            "into": "logs"
          },
          {
            "op": "compute",
            "fn": "current_streak",
            "args": [
              {
                "var": "logs"
              },
              "loggedAt"
            ],
            "into": "cur"
          },
          {
            "op": "compute",
            "fn": "longest_streak",
            "args": [
              {
                "var": "logs"
              },
              "loggedAt"
            ],
            "into": "best"
          },
          {
            "op": "branch",
            "cond": {
              "gte": [
                {
                  "var": "best"
                },
                1
              ]
            },
            "then": [
              {
                "op": "format",
                "template": "Reading streak: {cur} day(s) current, {best} day(s) longest.",
                "into": "confirmationText"
              }
            ],
            "else": [
              {
                "op": "format",
                "template": "No reading logged yet — log a session to start a streak.",
                "into": "confirmationText"
              }
            ]
          }
        ]
      }
    }
  ],
