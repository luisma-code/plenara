{
  "skillId": "list-meals",
  "displayName": "Meals today",
  "reads": [
    "meal"
  ],
  "writes": [],
  "inputs": [],
  "steps": {
    "main": [
      {
        "op": "compute",
        "fn": "today",
        "into": "today"
      },
      {
        "op": "read_many",
        "typeId": "meal",
        "filter": { "field": "loggedAt", "op": "gte", "value": { "var": "today" } },
        "orderBy": "loggedAt",
        "orderDir": "asc",
        "into": "meals"
      },
      {
        "op": "enumerate",
        "list": { "var": "meals" },
        "label": "food",
        "into": "out"
      },
      {
        "op": "compute",
        "fn": "count",
        "args": [ { "var": "meals" } ],
        "into": "n"
      },
      {
        "op": "branch",
        "cond": {
          "eq": [
            {
              "var": "n"
            },
            0
          ]
        },
        "then": [
          {
            "op": "format",
            "template": "You haven't logged any meals today.",
            "into": "confirmationText"
          }
        ],
        "else": [
          {
            "op": "format",
            "template": "Today you've eaten:{out}",
            "into": "confirmationText"
          }
        ]
      }
    ]
  }
}
