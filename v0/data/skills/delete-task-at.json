{
  "skillId": "delete-task-at",
  "displayName": "Delete a task by its position",
  "reads": [
    "task"
  ],
  "writes": [
    "task"
  ],
  "inputs": [
    { "name": "pos", "required": true }
  ],
  "steps": {
    "main": [
      {
        "op": "read_many",
        "typeId": "task",
        "filter": { "field": "completed", "op": "neq", "value": true },
        "orderBy": "createdAt",
        "orderDir": "asc",
        "into": "tasks"
      },
      { "op": "compute", "fn": "position_index", "args": [ { "var": "pos" } ], "into": "idx" },
      { "op": "compute", "fn": "nth", "args": [ { "var": "tasks" }, { "var": "idx" } ], "into": "target" },
      {
        "op": "branch",
        "cond": { "notNull": "target" },
        "then": [
          { "op": "set", "var": "desc", "value": { "field": [ "target", "description" ] } },
          { "op": "delete_record", "id": { "field": [ "target", "id" ] } },
          { "op": "format", "template": "Deleted \"{desc}\" from your tasks. (Say \"undo that\" to restore it.)", "into": "confirmationText" }
        ],
        "else": [
          { "op": "format", "template": "I couldn't find that task — you may not have that many.", "into": "confirmationText" }
        ]
      }
    ]
  }
}
