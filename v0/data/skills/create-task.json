{
  "skillId": "create-task",
  "displayName": "Create a task",
  "reads": [],
  "writes": [
    "task"
  ],
  "inputs": [
    {
      "name": "description",
      "required": true
    },
    {
      "name": "dueDate",
      "required": false,
      "type": "date"
    }
  ],
  "steps": {
    "main": [
      {
        "op": "compute",
        "fn": "now",
        "into": "createdAt"
      },
      { "op": "compute", "fn": "split_list", "args": [ { "var": "description" } ], "into": "items" },
      { "op": "compute", "fn": "count", "args": [ { "var": "items" } ], "into": "itemCount" },
      {
        "op": "branch",
        "cond": { "gte": [ { "var": "itemCount" }, 2 ] },
        "then": [
          { "op": "set", "var": "names", "value": "" },
          {
            "op": "foreach",
            "list": { "var": "items" },
            "as": "item",
            "body": [
              {
                "op": "write_record",
                "typeId": "task",
                "fields": {
                  "description": { "var": "item" },
                  "dueAt": { "var": "dueDate" },
                  "createdAt": { "var": "createdAt" }
                },
                "into": "newTask"
              },
              { "op": "compute", "fn": "concat", "args": [ { "var": "names" }, "\n  • ", { "var": "item" } ], "into": "names" }
            ]
          },
          {
            "op": "branch",
            "cond": { "notNull": "dueDate" },
            "then": [
              { "op": "compute", "fn": "format_date", "args": [ { "var": "dueDate" }, "EEEE" ], "into": "dueLabel" },
              { "op": "format", "template": "Added {itemCount} tasks, due {dueLabel}:{names}", "into": "confirmationText" }
            ],
            "else": [
              { "op": "format", "template": "Added {itemCount} tasks:{names}", "into": "confirmationText" }
            ]
          }
        ],
        "else": [
      {
        "op": "write_record",
        "typeId": "task",
        "fields": {
          "description": {
            "var": "description"
          },
          "dueAt": {
            "var": "dueDate"
          },
          "createdAt": {
            "var": "createdAt"
          }
        },
        "into": "newTask"
      },
      {
        "op": "branch",
        "cond": {
          "notNull": "dueDate"
        },
        "then": [
          {
            "op": "compute",
            "fn": "format_date",
            "args": [
              {
                "var": "dueDate"
              },
              "EEEE"
            ],
            "into": "dueLabel"
          },
          {
            "op": "format",
            "template": "Added \"{description}\" to your tasks, due {dueLabel}.",
            "into": "confirmationText"
          }
        ],
        "else": [
          {
            "op": "format",
            "template": "Added \"{description}\" to your tasks.",
            "into": "confirmationText"
          }
        ]
      }
        ]
      }
    ]
  }
}
