{
  "skillId": "set-daily-reminder",
  "displayName": "Set a daily recurring reminder",
  "reads": [],
  "writes": [
    "reminder"
  ],
  "inputs": [
    { "name": "text", "required": true },
    { "name": "when", "required": true, "type": "datetime", "prompt": "What time each day? (e.g. \"9am\")" }
  ],
  "steps": {
    "main": [
      { "op": "compute", "fn": "now", "into": "createdAt" },
      {
        "op": "write_record",
        "typeId": "reminder",
        "fields": {
          "text": { "var": "text" },
          "remindAt": { "var": "when" },
          "recurrence": "daily",
          "createdAt": { "var": "createdAt" }
        },
        "into": "newReminder"
      },
      { "op": "compute", "fn": "format_time", "args": [ { "var": "when" } ], "into": "timeLabel" },
      { "op": "format", "template": "Okay — I'll remind you to {text} every day at {timeLabel}.", "into": "confirmationText" }
    ]
  }
}
